#module
#defcfunc _padstick
	key = _ems32@(252)
	_ems32@(252) = 0
	return key

#defcfunc _padnum
	result = _ems32@(251)
	return result

#defcfunc _padd int index0
	result = _emf64@(index0)
	return result

#defcfunc _padi int index1
	result = _ems32@(index1)
	return result

#global

*preini

	_maxtouch = 0

	sdim _embuf, 4096 + 8*256 + 4*256
	_pembuf = varptr(_embuf)
	// 16バイトアライン
	_palign = ((_pembuf + 15) >> 4) << 4
	_pf64 = _palign + (4096-16)
	_ps32 = _pf64 + 8 * 256
	dupptr _emf64, _pf64, 8*256, vartype("double")
	dupptr _ems32, _ps32, 4*256, vartype("int")

	_pstr0 = _palign
	dupptr _emstr0, _pstr0, 1024, vartype("str")

	if _isem == 0 {
		return
	}

	code = ""
	code += strf("const _pf64 = %d;\n", _pf64)
	code += strf("const _ps32 = %d;\n", _ps32)
	code += {"
const _f64 = new Float64Array(Module.HEAPF64.buffer, _pf64, 256);
const _s32 = new Int32Array(Module.HEAP32.buffer, _ps32, 256);
window._f64 = _f64;
window._s32 = _s32;

const numNP = navigator.maxTouchPoints ?? 0;
_s32[254] = numNP;

const ua = navigator.userAgent.toLowerCase();
let osbit = 0;
if (ua.includes('windows')) {
  osbit |= 1;
}
if (ua.includes('android')) {
  osbit |= 2;
}
if (ua.includes('iphone')) {
  osbit |= 4;
}
if (ua.includes('ipad')) {
  osbit |= 8;
}
if (ua.includes('macintosh')) {
  osbit |= 0x10;
}
_s32[255] = osbit;

let _prez = 0;
let _prex = 0;
let _prec = 0;

let _predcup = 0;
let _predcdown = 0;
let _predcleft = 0;
let _predcright = 0;

const _update = () => {
  requestAnimationFrame(() => {
    _update();
  });

  { // パッド
    let padnum = 0;
    const povbits = [2, 6, 4, 12, 8, 9, 1, 3];
    //const dead = 0.25;
    const dead = 0.5;
    const gs = navigator.getGamepads();
    let bp = 0;
    for (const g of gs) {
	  if (!g) {
	    continue;
	  }
	  padnum += 1
	  // 10軸
	  for (let i = 0; i < 10; ++i) {
	    const a = g.axes[i] || 0;
	    _f64[i] = a; // 最新で上書き
	  }
	  // 31bitまで
	  for (let i = 0; i < 31; ++i) {
	    const b = g.buttons[i]?.pressed ? 1 : 0;
	    bp |= b << i;
	  }

      let key = 0;

      const curz = (bp & 1) ? 1 : 0;
	  const curx = (bp & 2) ? 1 : 0;
	  const curc = (bp & 4) ? 1 : 0;

/*
	  if ((1 - _prex) & curx) {
	    key |= 0x1000; // X
	  }
	  if ((1 - _prez) & curz) {
	    key |= 0x0800; // Z
	  }
	  if ((1 - _prec) & curc) {
	    key |= 0x2000; // C
	  }
*/

	  if (curz) {
	    key |= 0x0800; // Z
	  }
	  if (curx) {
	    key |= 0x1000; // X
	  }
	  if (curc) {
	    key |= 0x2000; // C
	  }

	  _prex = curx;
	  _prez = curz;
	  _prec = curc;

	  const ax = _f64[0];
	  const ay = _f64[1];
	  const pov = _f64[9];
	  if (Math.abs(ax) > dead) {
		// 左と右
	    key |= (ax < 0) ? 0x1 : 0x4;
	  }
	  if (Math.abs(ay) > dead) {
		// 上と下
	    key |= (ay < 0) ? 0x2 : 0x8;
	  }
	  if (pov) {
	    let dir = Math.round((pov + 1) * 7 / 2);
	    if (dir >= 0 && dir < 7) {
          key |= povbits[dir];
		}
	  }

	  const curdcup = (bp & (1 << 12)) ? 1 : 0;
	  const curdcdown = (bp & (1 << 13)) ? 1 : 0;
	  const curdcleft = (bp & (1 << 14)) ? 1 : 0;
	  const curdcright = (bp & (1 << 15)) ? 1 : 0;

/*
      if ((1 - _predcup) & curdcup) {
	    key |= 0x2;
      }
      if ((1 - _predcdown) & curdcdown) {
	    key |= 0x8;
	  }
	  if ((1 - _predcleft) & curdcleft) {
	    key |= 0x1;
	  }
	  if ((1 - _predcright) & curdcright) {
        key |= 0x4;
      }
*/
      if (curdcup) {
	    key |= 0x2;
      }
      if (curdcdown) {
	    key |= 0x8;
	  }
	  if (curdcleft) {
	    key |= 0x1;
	  }
	  if (curdcright) {
        key |= 0x4;
      }


      _predcup = curdcup;
      _predcdown = curdcdown;
      _predcleft = curdcleft;
	  _predcright = curdcright;

	  _s32[252] |= key; // or で追加
	}
	_s32[251] = padnum;
	_s32[253] |= bp; // 無加工の最新状態の or
  }

};
_update();
"}
	exec code
	_maxtouch = _ems32(254)
	return

