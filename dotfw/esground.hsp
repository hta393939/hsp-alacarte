#include "dotfw.as"
#define BGPIC_ID (0)
#define MYMAP_ID (1)

#define BGFRONT_ID (2)

	chdir "data"
// 左右のみ
	//df_config "ps2 Z150"
	df_config "X320 Y240 Z200 vpad"
	//df_config "X320 Y240 Z200 vpad"
	//df_config "X256 Y192 Z200"
	df_reset

	hspvpad_set 2, -1 // 上
	hspvpad_set 3, -1 // 下
	hspvpad_set 4, -1 // v←
	//hspvpad_set 5, -1 // o→Z ジャンプ
	hspvpad_set 6, -1 // A↑ X
	//hspvpad_set 7, -1 // ロ↓C

	//df_loadbgmap MYMAP_ID, "test2.tmap"	; マップファイル読み込み
	df_loadbgmap MYMAP_ID, "belt16_16_1.tmap"	; マップファイル読み込み
	mapsx = _dotfw_curmapx			; マップサイズXを取得
	mapsy = _dotfw_curmapy			; マップサイズYを取得
	df_getbgmap map, MYMAP_ID		; マップ配列変数を取得

	//df_bgpoint 0, 10,10

	//df_mapaction MYMAP_ID, 0, 6 ; 重力無し
	df_mapaction MYMAP_ID, 60, 6 ; 重力とジャンプ(80, 8とか)

	df_bgview MYMAP_ID, 90,90, 10,10, 32,32	; スクロール設定
	df_paction *player_mapev,PACTION_MAPITEM	; マップイベント処理

		df_celload bgcel,"tamane16.png"		; キャラクターの画像ファイル
		es_sizeex 16,16, ,16,16, 0,0		; キャラクターのサイズ指定
		es_patanim 0, 4, 0,16, 0, bgcel	; キャラクターの登録(0)
		es_patanim 4, 4, 64,16, 0, bgcel	; キャラクターの登録(4)

	df_addplayer 200,90,0			; プレイヤーを追加
	//df_pmode 0, 2	; 移動スピード(16ドットにはX=2がいい感じ
	df_pmode 0, 2, 2

	df_paction *onmapnotice,PACTION_MAPNOTICE

// 4: notice , 2: event, 1: hold

	
*main
	// key は dotfw でセットされるのか
	if key&PLAYER_KEY_ESC : end		; [ESC]キーで終了
	
	df_getplayer
	mysp = _dotfw_cursp
	i=0:if _dotfw_mydir=DIR_RIGHT : i=4
	j=(_dotfw_myani>>2)&3
	if _dotfw_myact!=1 : j=0
	es_chr _dotfw_cursp, i+j

	if key & PLAYER_KEY_BUTTON3 {
		// 0下から反時計周り
		dir = DIR_LEFT
		dir = _dotfw_mydir // ジャンプ時のみらしい
		if dir == DIR_LEFT {
			mv = -1
		} else {
			mv = 1
		}
		df_addpmis _dotfw_myx + mv * 8, _dotfw_myy, dir, 100 * 2, 0, 0
	} // 2000h C

	es_bghit mysp
	es_get result, mysp, ESI_MOVERES
	col = 0
	if result & ESSPRES_GROUND {
		col = 7
		gcnt += 1
	}
	if result & ESSPRES_YBLOCK {
		ycnt += 1
	}
	lx = 5
	df_mes strf("moveres, %04X", result), lx, 9, col
	df_mes strf("moveres, %04X, %d   ", result & ESSPRES_YBLOCK, ycnt), lx, 10, col
	df_mes strf("moveres, %04X, %d   ", result & ESSPRES_GROUND, gcnt), lx, 11, col
	df_mes strf("%d", mapevcnt), lx, 12, col
	df_mes strf("notice, %d   ", noticecnt), lx, 13, col

	if key & 2 {
		es_setp mysp, ESI_ACCELY, 60, 0
	}
	
	if result & ESSPRES_GROUND {
		if nonfirst == 1 {
			//dialog "ここに来ない。つまりグランド判定にならない"
			//nonfirst = 2
			//es_setp mysp, ESI_SPDY, 1 * 65536, 0
			//es_setp mysp, ESI_ACCELY, 60, 0
		}
		if nonfirst == 0 {
			nonfirst = 1
			//es_setp mysp, ESI_SPDY, 0 * 65536, 0
			//es_setp mysp, ESI_SPDY, 4 * 65536, 0
			//es_setp mysp, ESI_ACCELY, 0 * 65536 + 60 * 0 + 1 * 0 - 1, 0
			//es_setp mysp, ESI_POSY, 20 * 65536, 0
			//es_setp mysp, ESI_MAPHIT, 0, 0
		}
	}


	df_update
	goto *main

*onmapnotice
	noticecnt += 1
	return

*player_mapev
	// bit 2
	mapevcnt += 1
	;	イベント処理
	op=_dotfw_curmapattr
	if op==0 {
		; アイテム取得
		map(mapsx*_dotfw_curmapy+_dotfw_curmapx)=0	; アイテムを消す
	}
	if op==1 {
		goto *miss
	}
	if op == 2 {
		es_setp mysp, ESI_SPDY, 0 * 65536, 0
		es_setp mysp, ESI_ACCELY, 60 * 0, 0
		//es_setp mysp, ESI_POSY, 20 * 65536, 0
	}
	return

*mesrest
	return
*miss
	//df_pwipe ; プレイヤーを消去
	return
